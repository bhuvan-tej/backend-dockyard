# ── Maven build output ────────────────────────────────────────────────
# The target folder is generated by Maven on every build
# It contains compiled classes, JARs and test reports
# Never commit this — it is regenerated by running mvn clean install
target/

# ── IntelliJ IDEA ─────────────────────────────────────────────────────
# These are IDE specific files that are different on every developer machine
# Committing them causes constant merge conflicts between team members
.idea/
*.iml
*.iws
*.ipr
out/

# ── Spring Boot specific ──────────────────────────────────────────────
# Spring Boot DevTools restart trigger file
.spring-boot-devtools.properties

# ── OS generated files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────
# Log files are generated at runtime and should never be in version control
*.log
logs/

# ── Secrets — never commit these ──────────────────────────────────────
# Environment files often contain database passwords and API keys
# If you commit these by accident rotate your credentials immediately
.env
*.env.*
*.key
*.pem

# ── Test files generated at runtime ───────────────────────────────────
# These are generated by test runs and change constantly
*.exec

# ── HTTP client test files ────────────────────────────────────────────
# Keep the .http files but ignore any response files IntelliJ generates
.idea/httpRequests/